generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FlowType {
  income
  expense
}

enum FitsseyAuthMode {
  apiKey
  basic
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  description String
  amount      Float
  category    String
  date        DateTime
  createdAt   DateTime @default(now())

  @@index([userId, date])
}

model FlowRow {
  id         String   @id @default(cuid())
  userId     String
  type       FlowType
  name       String
  isImported Boolean  @default(false)
  vatRate    Float?
  amount     Float
  startMonth String
  endMonth   String?
  monthValues Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, type])
}

model FitsseySettings {
  id                      String          @id @default(cuid())
  userId                  String          @unique
  studioUuid              String
  authMode                FitsseyAuthMode @default(apiKey)
  apiKey                  String?
  username                String?
  password                String?
  startDate               DateTime?
  citRate                 Float           @default(19)
  vatRate                 Float           @default(23)
  autoImportEnabled       Boolean         @default(true)
  autoImportIntervalMins  Int             @default(180)
  lastImportedAt          DateTime?
  lastImportStatus        String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([userId])
}

model FitsseyClient {
  id             String   @id @default(cuid())
  userId         String
  externalGuid   String
  clientUuid     String?
  fullName       String
  normalizedName String
  email          String?
  phone          String?
  activeEntries  Int?
  entriesSource  String?
  entriesUpdatedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, externalGuid])
  @@index([userId, clientUuid])
  @@index([userId, normalizedName])
}
