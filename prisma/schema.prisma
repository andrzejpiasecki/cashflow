generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FlowType {
  income
  expense
}

enum FitsseyAuthMode {
  apiKey
  basic
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  description String
  amount      Float
  category    String
  date        DateTime
  createdAt   DateTime @default(now())

  @@index([userId, date])
}

model FlowRow {
  id         String   @id @default(cuid())
  userId     String
  type       FlowType
  name       String
  isImported Boolean  @default(false)
  amount     Float
  startMonth String
  endMonth   String?
  monthValues Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, type])
}

model FitsseySettings {
  id                      String          @id @default(cuid())
  userId                  String          @unique
  studioUuid              String
  authMode                FitsseyAuthMode @default(apiKey)
  apiKey                  String?
  username                String?
  password                String?
  startDate               DateTime?
  citRate                 Float           @default(19)
  vatRate                 Float           @default(23)
  autoImportEnabled       Boolean         @default(true)
  autoImportIntervalMins  Int             @default(180)
  lastImportedAt          DateTime?
  lastImportStatus        String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([userId])
}
