generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FlowType {
  income
  expense
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  description String
  amount      Float
  category    String
  date        DateTime
  createdAt   DateTime @default(now())

  @@index([userId, date])
}

model FlowRow {
  id         String   @id @default(cuid())
  userId     String
  type       FlowType
  name       String
  amount     Float
  startMonth String
  endMonth   String?
  monthValues Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, type])
}
